# Copy to .env:
#   cp .env.example .env

# Select backend for /api/music/compose
MUSIC_PROVIDER=acestep

# ACE-Step (local)
ACESTEP_DIR=vendor/acestep
ACESTEP_PYTHON=python3
ACESTEP_DEVICE=auto
ACESTEP_CONFIG_PATH=acestep-v15-turbo
# Prefer download source for large checkpoints: auto|huggingface|modelscope
ACESTEP_PREFER_SOURCE=auto
ACESTEP_TIMEOUT_MS=3600000

# HeartMuLa / heartlib (local)
# Note: HeartMuLa typically requires an NVIDIA GPU (CUDA). macOS Apple Silicon is not officially supported.
HEARTLIB_DIR=vendor/heartlib
HEARTMULA_CKPT_DIR=vendor/heartlib/ckpt
HEARTMULA_VERSION=3B
# Optional: 7B is supported by heartlib, but may not have public weights yet.
# HEARTMULA_VERSION=7B
HEARTMULA_PYTHON=python3
HEARTMULA_MULA_DEVICE=cuda
HEARTMULA_CODEC_DEVICE=cuda
HEARTMULA_MULA_DTYPE=bf16
HEARTMULA_CODEC_DTYPE=float32
HEARTMULA_LAZY_LOAD_MODEL=true
HEARTMULA_TIMEOUT_MS=1800000

# ElevenLabs (optional fallback)
ELEVENLABS_API_KEY=

# Optional
PORT=3000
GENERATED_DIR=generated
